<Window x:Class="BazaarArena.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Bazaar Arena" Height="600" Width="900"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Menu Grid.Row="0">
            <MenuItem Header="文件(_F)">
                <MenuItem Header="新建卡组" Click="NewDeck_Click"/>
                <MenuItem Header="打开卡组..." Click="OpenDeck_Click"/>
                <Separator/>
                <MenuItem Header="退出" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="模拟(_S)">
                <MenuItem Header="单次模拟..." Click="SingleSimulate_Click"/>
                <MenuItem Header="批量模拟..." Click="BatchSimulate_Click"/>
                <MenuItem Header="卡组互评..." Click="DeckCompare_Click"/>
            </MenuItem>
        </Menu>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <!-- 左侧：卡组列表 -->
            <Border Grid.Column="0" BorderBrush="#ccc" BorderThickness="0,0,1,0" Padding="8">
                <StackPanel>
                    <TextBlock Text="已保存的卡组" FontWeight="Bold" Margin="0,0,0,6"/>
                    <ListBox x:Name="DeckListBox" Height="280" SelectionChanged="DeckListBox_SelectionChanged"
                             DisplayMemberPath="Display"/>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="新建" Click="NewDeck_Click" Padding="8,4" Margin="0,0,4,0"/>
                        <Button Content="删除" Click="DeleteDeck_Click" Padding="8,4"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            <!-- 右侧：编辑区或欢迎语 -->
            <Grid Grid.Column="1">
                <TextBlock x:Name="WelcomeText" Text="欢迎使用 Bazaar Arena。从左侧选择卡组或点击「新建」开始编辑；也可使用菜单进行模拟对战。" 
                           TextWrapping="Wrap" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="24" FontSize="14"/>
                <ScrollViewer x:Name="EditorPanel" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" Padding="16"
                              DataContext="{Binding RelativeSource={RelativeSource AncestorType=Window}}">
                    <StackPanel>
                        <TextBlock Text="玩家等级 (1–20)" FontWeight="Bold" Margin="0,0,0,4"/>
                        <ComboBox x:Name="PlayerLevelCombo" Width="120" HorizontalAlignment="Left" Margin="0,0,0,12" SelectionChanged="PlayerLevel_Changed"/>
                        <TextBlock x:Name="SlotSummaryText" Margin="0,0,0,8"/>
                        <TextBlock Text="卡组（可拖拽调整顺序，拖至「删除」区移除）" FontWeight="Bold" Margin="0,0,0,4"/>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="DeleteDropZone" Grid.Column="0" Width="56" MinHeight="80" Margin="0,0,8,0"
                                    Background="#400000" BorderBrush="#888" BorderThickness="1" CornerRadius="4"
                                    VerticalAlignment="Stretch" AllowDrop="True" DragOver="DeleteZone_DragOver" Drop="DeleteZone_Drop">
                                <TextBlock Text="删除" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#CCC" FontSize="12"/>
                            </Border>
                            <Border x:Name="DeckGridDropZone" Grid.Column="1" VerticalAlignment="Top" BorderBrush="#ccc" BorderThickness="1" CornerRadius="4" Padding="4" Background="#1a1a1a"
                                    AllowDrop="True" DragOver="DeckGrid_DragOver" Drop="DeckGrid_Drop">
                                <Grid x:Name="DeckGridInner" SizeChanged="DeckGridInner_SizeChanged">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="14"/>
                                        <RowDefinition Height="80"/>
                                        <RowDefinition Height="Auto" MinHeight="28"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid x:Name="TierRowGrid" Grid.Row="0" Grid.ColumnSpan="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                    </Grid>
                                    <Grid x:Name="DeckImageRowGrid" Grid.Row="1" Grid.ColumnSpan="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                    </Grid>
                                    <Grid x:Name="DeckNameRowGrid" Grid.Row="2" Grid.ColumnSpan="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                    </Grid>
                                </Grid>
                            </Border>
                            <Border Grid.Column="2" Width="56" Margin="8,0,0,0" Background="Transparent"/>
                        </Grid>
                        <TextBlock Text="添加物品（拖拽到卡组中加入）" FontWeight="Bold" Margin="0,0,0,4"/>
                        <ItemsControl x:Name="ItemPoolList" Margin="0,0,0,12">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border MinWidth="64" Width="96" Margin="0,0,8,8" Padding="4" Background="#2a2a2a" BorderBrush="#555" BorderThickness="1" CornerRadius="4"
                                            Cursor="Hand" PreviewMouseLeftButtonDown="ItemPoolTile_PreviewMouseLeftButtonDown">
                                        <StackPanel>
                                            <Border Height="48" Margin="0,0,0,4" Background="#333" CornerRadius="2">
                                                <Image Source="{Binding Converter={StaticResource ItemNameToImage}}" Stretch="Uniform" Height="48"/>
                                            </Border>
                                            <TextBlock Text="{Binding}" FontSize="11" Foreground="#eee" TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="保存" Click="SaveDeck_Click" Padding="12,6" Margin="0,0,8,0"/>
                            <Button Content="另存为..." Click="SaveAsDeck_Click" Padding="12,6"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Window>
