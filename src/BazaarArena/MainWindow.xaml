<Window x:Class="BazaarArena.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Bazaar Arena" Height="600" Width="900"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Menu Grid.Row="0">
            <MenuItem Header="文件(_F)">
                <MenuItem Header="新建卡组" Click="NewDeck_Click"/>
                <MenuItem Header="打开卡组..." Click="OpenDeck_Click"/>
                <Separator/>
                <MenuItem Header="退出" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="模拟(_S)">
                <MenuItem Header="单次模拟..." Click="SingleSimulate_Click"/>
                <MenuItem Header="批量模拟..." Click="BatchSimulate_Click"/>
                <MenuItem Header="卡组互评..." Click="DeckCompare_Click"/>
            </MenuItem>
        </Menu>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <!-- 左侧：卡组列表 -->
            <Border Grid.Column="0" BorderBrush="#ccc" BorderThickness="0,0,1,0" Padding="8">
                <StackPanel>
                    <TextBlock Text="已保存的卡组" FontWeight="Bold" Margin="0,0,0,6"/>
                    <ListBox x:Name="DeckListBox" Height="280" SelectionChanged="DeckListBox_SelectionChanged"
                             DisplayMemberPath="."/>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="新建" Click="NewDeck_Click" Padding="8,4" Margin="0,0,4,0"/>
                        <Button Content="删除" Click="DeleteDeck_Click" Padding="8,4"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            <!-- 右侧：编辑区或欢迎语 -->
            <Grid Grid.Column="1">
                <TextBlock x:Name="WelcomeText" Text="欢迎使用 Bazaar Arena。从左侧选择卡组或点击「新建」开始编辑；也可使用菜单进行模拟对战。" 
                           TextWrapping="Wrap" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="24" FontSize="14"/>
                <ScrollViewer x:Name="EditorPanel" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" Padding="16">
                    <StackPanel>
                        <TextBlock Text="玩家等级 (1–20)" FontWeight="Bold" Margin="0,0,0,4"/>
                        <ComboBox x:Name="PlayerLevelCombo" Width="120" HorizontalAlignment="Left" Margin="0,0,0,12" SelectionChanged="PlayerLevel_Changed"/>
                        <TextBlock x:Name="SlotSummaryText" Margin="0,0,0,8"/>
                        <TextBlock Text="卡组槽位（从左到右）" FontWeight="Bold" Margin="0,0,0,4"/>
                        <ItemsControl x:Name="SlotEntriesList" Margin="0,0,0,12">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="4" Margin="0,2" Background="#fafafa" BorderBrush="#ddd" BorderThickness="1" CornerRadius="2">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="32" Height="32" Margin="0,0,8,0" Background="#e0e0e0" CornerRadius="2">
                                                <Image Source="{Binding ItemName, Converter={StaticResource ItemNameToImage}}" Stretch="Uniform" />
                                            </Border>
                                            <ComboBox Grid.Column="1" ItemsSource="{Binding ItemNames}" SelectedItem="{Binding ItemName, UpdateSourceTrigger=PropertyChanged}" 
                                                      MinWidth="140" Margin="0,0,8,0"/>
                                            <ComboBox Grid.Column="2" ItemsSource="{Binding TierList}" SelectedItem="{Binding Tier, UpdateSourceTrigger=PropertyChanged}" 
                                                      Width="80" Margin="0,0,8,0"/>
                                            <Button Grid.Column="3" Content="移除" Click="RemoveSlot_Click" Tag="{Binding}" Padding="6,2"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="添加物品：" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <ComboBox x:Name="AddItemNameCombo" MinWidth="140" Margin="0,0,6,0"/>
                            <ComboBox x:Name="AddTierCombo" Width="80" Margin="0,0,6,0"/>
                            <Button Content="添加" Click="AddSlot_Click" Padding="8,4"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="保存" Click="SaveDeck_Click" Padding="12,6" Margin="0,0,8,0"/>
                            <Button Content="另存为..." Click="SaveAsDeck_Click" Padding="12,6"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Window>
