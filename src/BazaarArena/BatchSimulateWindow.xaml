<Window x:Class="BazaarArena.BatchSimulateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="批量模拟" Height="320" Width="480" WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
            <TextBlock Text="玩家1 卡组：" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <ComboBox x:Name="DeckACombo" MinWidth="280" DisplayMemberPath="Display"/>
        </StackPanel>
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="玩家2 卡组：" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <ComboBox x:Name="DeckBCombo" MinWidth="280" DisplayMemberPath="Display"/>
        </StackPanel>
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="模拟场次：" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBox x:Name="RunsBox" Width="80" Padding="4" VerticalContentAlignment="Center" Text="1000"/>
        </StackPanel>
        <Button Grid.Row="3" Content="开始批量模拟" Click="Run_Click" Padding="12,6" HorizontalAlignment="Left" Margin="0,0,0,12"/>
        <Border Grid.Row="4" BorderBrush="#ddd" BorderThickness="1" Padding="8" Background="#fafafa" Margin="0,0,0,8">
            <StackPanel>
                <TextBlock x:Name="ProgressText" Text="" TextWrapping="Wrap" Margin="0,0,0,6"/>
                <ProgressBar x:Name="ProgressBar" Height="8" Minimum="0" Maximum="1" Value="0"/>
            </StackPanel>
        </Border>
        <TextBlock x:Name="ResultText" Grid.Row="5" FontWeight="Bold" Text="" TextWrapping="Wrap"/>
    </Grid>
</Window>
