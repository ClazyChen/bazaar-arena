<Window x:Class="BazaarArena.SaveAsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="另存为" Height="160" Width="320" WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Text="输入卡组名称（用于保存）：" Margin="0,0,0,8"/>
        <TextBox x:Name="DeckIdBox" Grid.Row="1" Padding="4" Margin="0,0,0,16" VerticalContentAlignment="Center"/>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="确定" IsDefault="True" Click="Ok_Click" Padding="12,6" Margin="0,0,8,0"/>
            <Button Content="取消" IsCancel="True" Padding="12,6"/>
        </StackPanel>
    </Grid>
</Window>
